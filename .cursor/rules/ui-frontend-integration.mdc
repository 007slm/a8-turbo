### 性能监控
```jsx
// 性能监控 Hook
const usePerformanceMonitor = (operationName) => {
    const [metrics, setMetrics] = useState({});
    
    const trackOperation = (fn) => async (...args) => {
        const startTime = performance.now();
        try {
            const result = await fn(...args);
            const endTime = performance.now();
            setMetrics(prev => ({
                ...prev,
                [operationName]: endTime - startTime
            }));
            return result;
        } catch (error) {
            // 错误追踪
            throw error;
        }
    };
    
    return { trackOperation, metrics };
};
```

