{
  "name": "monitoring-stream",
  "subjects": [
    "monitoring.*"
  ],
  "retention": "limits",
  "max_consumers": -1,
  "max_msgs_per_subject": 10000,
  "max_msgs": -1,
  "max_bytes": -1,
  "max_age": 3600000000000,
  "max_msg_size": -1,
  "storage": "file",
  "discard": "old",
  "num_replicas": 1,
  "duplicate_window": 120000000000,
  "allow_rollup_hdrs": true,
  "allow_direct": true,
  "mirror_direct": false,
  "sealed": false,
  "deny_delete": false,
  "deny_purge": false,
  "allow_exclusive_write": false,
  "sources": [
    {
      "name": "cdc-stream"
    }
  ]
}