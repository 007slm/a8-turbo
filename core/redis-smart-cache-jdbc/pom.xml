        <artifactId>redis-smart-cache</artifactId>
        <version>0.2.2-SNAPSHOT</version>
        <relativePath>../../pom.xml</relativePath>
    </parent>

    <artifactId>redis-smart-cache-jdbc</artifactId>

    <name>Redis Smart Cache JDBC</name>
    <description>JDBC components for Redis Smart Cache</description>

    <dependencies>
        <dependency>
            <groupId>com.redis</groupId>
            <artifactId>redis-smart-cache-core</artifactId>
            <exclusions>
                <exclusion>
                    <groupId>com.redis</groupId>
                    <artifactId>testcontainers-redis</artifactId>
                </exclusion>
            </exclusions>
        </dependency>
        
        <dependency>
            <groupId>com.redis</groupId>
            <artifactId>lettucemod</artifactId>
        </dependency>
        
        <dependency>
            <groupId>io.micrometer</groupId>
