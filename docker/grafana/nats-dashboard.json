{
  "id": null,
  "title": "NATS Dashboard",
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 0,
  "refresh": "10s",
  "rows": [
    {
      "title": "NATS Metrics",
      "height": "250px",
      "panels": [
        {
          "title": "Connections",
          "type": "graph",
          "id": 1,
          "datasource": "Prometheus",
          "targets": [
            {
              "expr": "nats_varz_connections",
              "format": "time_series",
              "intervalFactor": 2,
              "legendFormat": "Connections",
              "refId": "A"
            }
          ],
          "xaxis": {
            "mode": "time",
            "show": true
          },
          "yaxes": [
            {
              "format": "short",
              "logBase": 1,
              "show": true
            },
            {
              "format": "short",
              "logBase": 1,
              "show": true
            }
          ]
        },
        {
          "title": "Total Messages",
          "type": "graph",
          "id": 2,
          "datasource": "Prometheus",
          "targets": [
            {
              "expr": "nats_varz_in_msgs + nats_varz_out_msgs",
              "format": "time_series",
              "intervalFactor": 2,
              "legendFormat": "Messages",
              "refId": "A"
            }
          ],
          "xaxis": {
            "mode": "time",
            "show": true
          },
          "yaxes": [
